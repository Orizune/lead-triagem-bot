# Chave da API do Groq (obrigatória)
# Gere em: https://console.groq.com/keys
GROQ_API_KEY=

# Token do bot do Telegram (obrigatório)
# Gere em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# URL do ngrok (para desenvolvimento local)
# Exemplo: https://abc123.ngrok-free.app
WEBHOOK_URL=

# Chave do Gemini (opcional - alternativa ao Groq)
# Gere em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
